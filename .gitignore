# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tgz

# npm package vendored copies (generated at pack time by scripts/vendor.js; not committed)
packages/npm/bin/aid
packages/npm/bin/aid.ps1
packages/npm/bin/aid.cmd
packages/npm/lib/
packages/npm/dashboard/
packages/npm/VERSION

# PyPI package vendored copies (generated at build time by scripts/vendor.py; not committed)
packages/pypi/aid_installer/_vendor/
packages/pypi/dist/

# Logs and temp
*.log
*.tmp
*.temp
*.bak
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.iml
*.sublime-workspace
*.sublime-project

# Editor backups
*.orig

# Generated knowledge-summary cache
.aid/knowledge/.cache/

# Transient /aid-summarize review artifacts (regenerated each run)
.aid/knowledge/.manual-checklist.json
.aid/knowledge/.spot-check-facts.txt

# Claude Code files
.claude/worktrees/
.claude/projects/
.claude/settings.local.json

# Subagent heartbeat files (ephemeral runtime artifacts; visibility-patch L3)
.aid/.heartbeat/

# Transient AID lifecycle scratch + review-pending ledgers (explicit dir entry,
# not just the *.temp glob above — resilient to a future rename)
.aid/.temp/

# Reversible-migration trash dir (W3): retired AID-owned files moved here by
# _migrate_retired_layout; never committed so users can inspect/restore but
# don't accidentally track recovered files.
.aid/.trash/

# generator verify-report default output path (verify_deterministic.py / verify_advisory.py) -- tooling artifact, not a work
.aid/work-002-canonical-generator/
