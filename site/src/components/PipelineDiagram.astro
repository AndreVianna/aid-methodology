---
// PipelineDiagram.astro — the AID pipeline as inline pill-steps (prototype-01).
// A single, primary, lightweight representation: aid-config (bootstrap) → the six
// numbered phases → the two optional Deliver skills. Self-contained scoped styles.
const core = [
  { label: 'Discover' },
  { label: 'Interview' },
  { label: 'Specify' },
  { label: 'Plan' },
  { label: 'Detail' },
  { label: 'Execute' },
];
---

<div
  class="pipeline"
  role="img"
  aria-label="AID pipeline: aid-config, then the six numbered phases Discover, Interview, Specify, Plan, Detail, Execute, then the two optional Deliver skills Deploy and Monitor"
>
  <div class="pipe-row">
    <span class="step config"><span class="dot"></span>aid-config</span>
    <span class="arrow" aria-hidden="true"
      ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
      ></span
    >
    {
      core.map((s, i) => (
        <>
          <span class="step">
            <span class="dot" />
            {s.label}
          </span>
          {i < core.length - 1 && (
            <span class="arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          )}
        </>
      ))
    }
    <span class="pipe-divider" aria-hidden="true">·</span>
    <span class="step optional"><span class="dot"></span>Deploy</span>
    <span class="arrow" aria-hidden="true"
      ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        ><path d="M5 12h14M13 6l6 6-6 6"></path></svg
      ></span
    >
    <span class="step optional"><span class="dot"></span>Monitor</span>
  </div>
  <div class="pipe-caption">
    Solid steps are the core path — the six numbered phases, gated by a human review between each.
    <code>aid-config</code> runs once to set up. Dashed steps (Deploy · Monitor) are optional,
    on-demand Deliver skills, not numbered phases.
  </div>
</div>

<style>
  .pipeline {
    margin: 22px 0 8px;
    padding: 24px 22px;
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--casulo-radius, 12px);
    background: var(--sl-color-bg-nav);
  }
  .pipe-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .step {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 13px;
    border: 1px solid var(--casulo-border-strong, rgba(148, 163, 184, 0.16));
    border-radius: 999px;
    background: var(--sl-color-bg-inline-code);
    color: var(--sl-color-white);
    font-size: 13px;
    font-weight: 550;
    white-space: nowrap;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  .step:hover {
    border-color: var(--casulo-border-accent);
    transform: translateY(-1px);
  }
  .step .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--sl-color-accent);
    box-shadow: 0 0 0 3px var(--casulo-accent-glow);
  }
  .step.config {
    color: var(--sl-color-gray-2);
  }
  .step.config .dot {
    background: var(--sl-color-gray-3);
    box-shadow: none;
  }
  .step.optional {
    border-style: dashed;
    color: var(--sl-color-gray-2);
  }
  .step.optional .dot {
    background: var(--sl-color-gray-2);
    box-shadow: none;
  }
  .arrow {
    color: var(--sl-color-gray-3);
    flex: 0 0 auto;
    display: grid;
    place-items: center;
  }
  .arrow svg {
    width: 16px;
    height: 16px;
  }
  .pipe-divider {
    color: var(--sl-color-gray-3);
    font-weight: 600;
    padding: 0 2px;
  }
  .pipe-caption {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--sl-color-hairline);
    font-size: 13px;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
  }
  .pipe-caption code {
    font-size: 0.9em;
  }
</style>
