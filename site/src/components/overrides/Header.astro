---
// Header.astro — AID docs custom header (prototype-01 "faithful Claude/Mintlify").
//
// Two stacked rows that together fill --sl-nav-height:
//   row 1 (thin header): brand + search + GitHub/casuloailabs.com links + theme toggle
//   row 2 (section tabs): one tab per top-level sidebar group, section-aware (active state)
//
// Starlight's Search + ThemeSelect are reused (Pagefind index + theme persistence stay intact).
// We import the default implementations directly (we are not overriding those two), which keeps
// the imports type-checked — the documented pattern for reusing built-ins in an override.
// Tabs are derived from the live sidebar so they never drift from astro.config.mjs.
import Search from '@astrojs/starlight/components/Search.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
import casuloLogo from '../../assets/casulo-ai-labs.png';

const { sidebar } = Astro.locals.starlightRoute;

type AnyEntry = { type: string; label: string; href?: string; isCurrent?: boolean; entries?: AnyEntry[] };

function collectLinks(entries: AnyEntry[]): AnyEntry[] {
  const out: AnyEntry[] = [];
  for (const e of entries ?? []) {
    if (e.type === 'link') out.push(e);
    else if (e.type === 'group') out.push(...collectLinks(e.entries ?? []));
  }
  return out;
}

// Each top-level sidebar group becomes a section tab. The solo "Overview" link is
// the home doc and is reached via the brand, so it is intentionally not a tab.
const tabs = (sidebar as AnyEntry[])
  .filter((e) => e.type === 'group')
  .map((g) => {
    const links = collectLinks(g.entries ?? []);
    return {
      label: g.label,
      href: links[0]?.href ?? '#',
      isActive: links.some((l) => l.isCurrent),
    };
  });

const GITHUB_URL = 'https://github.com/AndreVianna/aid-methodology';
const CASULO_URL = 'https://casuloailabs.com';
---

<div class="aid-header">
  <div class="aid-header-bar">
    <div class="aid-brand-group">
      <a class="aid-casulo" href={CASULO_URL} target="_blank" rel="noopener" aria-label="Casulo AI Labs — casuloailabs.com">
        <img
          src={casuloLogo.src}
          width={casuloLogo.width}
          height={casuloLogo.height}
          alt="Casulo AI Labs"
        />
      </a>
      <span class="aid-brand-sep" aria-hidden="true"></span>
      <a class="aid-brand" href="/" aria-label="AID — AI Integrated Development, docs home">
        <span class="aid-name"><b>AID</b> <span>AI Integrated Development</span></span>
      </a>
    </div>

    <div class="aid-header-spacer"></div>

    <div class="aid-search print:hidden">
      <Search />
    </div>

    <nav class="aid-header-links print:hidden" aria-label="External links">
      <a class="aid-header-link" href={GITHUB_URL} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12a11.5 11.5 0 0 0 7.9 10.9c.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.7 1.2 3.3.9.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.9 1.2 1.9 1.2 3.2 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .4.2.7.8.6A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path></svg>
        <span>GitHub</span>
      </a>
    </nav>

    <div class="aid-theme print:hidden">
      <ThemeSelect />
    </div>
  </div>

  {
    tabs.length > 0 && (
      <nav class="aid-tabs print:hidden" aria-label="Documentation sections">
        <div class="aid-tabs-inner">
          {tabs.map((t) => (
            <a
              class:list={['aid-tab', { active: t.isActive }]}
              href={t.href}
              aria-current={t.isActive ? 'page' : undefined}
            >
              {t.label}
            </a>
          ))}
        </div>
      </nav>
    )
  }
</div>
