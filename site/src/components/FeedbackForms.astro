---
// FeedbackForms.astro — on-site feedback/issue forms for the AID docs.
//
// No backend: each form captures fields client-side, then opens GitHub's "New issue"
// page in a NEW TAB, fully prefilled (title + body + label). The reporter reviews and
// clicks Submit on GitHub (a free GitHub account is required), so the issue is filed by
// them and GitHub handles auth + spam. Nothing leaves the browser until that submit.
//
// Three types, each with its own pre-existing label:
//   Page issue       -> label "site issue"  (+ originating page auto-captured)
//   AID bug          -> label "bug"
//   General feedback -> label "feedback"
// Plus a Contact block (mailto) for private "request more info" inquiries.
const REPO = 'AndreVianna/aid-methodology';
const CONTACT_EMAIL = 'andre.vianna.rj@hotmail.com';
---

<section id="aid-feedback" class="fb" data-repo={REPO}>
  <div class="fb-tabs" role="tablist" aria-label="Feedback type">
    <button class="fb-tab active" role="tab" aria-selected="true" data-fbtab="page" type="button">Page issue</button>
    <button class="fb-tab" role="tab" aria-selected="false" data-fbtab="bug" type="button">AID bug</button>
    <button class="fb-tab" role="tab" aria-selected="false" data-fbtab="feedback" type="button">General feedback</button>
  </div>

  <p class="fb-note">
    Submitting opens a <strong>prefilled GitHub issue in a new tab</strong> — review it and click
    <em>Submit new issue</em> there. A free GitHub account is required; nothing is sent until you
    submit on GitHub.
  </p>

  {/* ---- Page issue ---- */}
  <div class="fb-panel" data-fbpanel="page">
    <p class="fb-desc">Something wrong with a documentation page — a typo, a broken link, an error, or anything unclear. The page is attached automatically.</p>
    <label class="fb-label" for="fb-page-url">Page <span class="fb-muted">(auto-filled)</span></label>
    <input class="fb-input" id="fb-page-url" type="text" placeholder="URL of the page" readonly />
    <input type="hidden" id="fb-page-title" />
    <label class="fb-label" for="fb-page-desc">What's the problem? <span class="fb-req">*</span></label>
    <textarea class="fb-input" id="fb-page-desc" rows="5" placeholder="Describe the issue with this page…"></textarea>
    <button class="fb-submit" id="fb-page-submit" type="button">Open prefilled issue on GitHub →</button>
  </div>

  {/* ---- AID bug ---- */}
  <div class="fb-panel" data-fbpanel="bug" hidden>
    <p class="fb-desc">A bug in AID itself — the CLI, a skill, an agent, or the pipeline behaving incorrectly.</p>
    <label class="fb-label" for="fb-bug-title">Summary <span class="fb-req">*</span></label>
    <input class="fb-input" id="fb-bug-title" type="text" placeholder="Short summary of the bug" />
    <label class="fb-label" for="fb-bug-what">What happened? <span class="fb-req">*</span></label>
    <textarea class="fb-input" id="fb-bug-what" rows="4" placeholder="What you did and what went wrong…"></textarea>
    <label class="fb-label" for="fb-bug-expected">What did you expect?</label>
    <textarea class="fb-input" id="fb-bug-expected" rows="2" placeholder="Expected behavior…"></textarea>
    <label class="fb-label" for="fb-bug-version">AID version / environment</label>
    <input class="fb-input" id="fb-bug-version" type="text" placeholder="e.g. aid v1.0.0, claude-code, macOS" />
    <button class="fb-submit" id="fb-bug-submit" type="button">Open prefilled issue on GitHub →</button>
  </div>

  {/* ---- General feedback ---- */}
  <div class="fb-panel" data-fbpanel="feedback" hidden>
    <p class="fb-desc">An idea, suggestion, or general comment about AID or the methodology.</p>
    <label class="fb-label" for="fb-fb-subject">Subject <span class="fb-req">*</span></label>
    <input class="fb-input" id="fb-fb-subject" type="text" placeholder="What's this about?" />
    <label class="fb-label" for="fb-fb-msg">Your feedback <span class="fb-req">*</span></label>
    <textarea class="fb-input" id="fb-fb-msg" rows="5" placeholder="Share your thoughts…"></textarea>
    <button class="fb-submit" id="fb-fb-submit" type="button">Open prefilled issue on GitHub →</button>
  </div>

  {/* ---- Contact (private) ---- */}
  <div class="fb-contact">
    <h3>Contact &amp; more info</h3>
    <p>
      Have a private question, or want to know more about adopting the AID methodology? This isn't a
      public issue — reach out directly:
    </p>
    <p>
      <a class="fb-mail" href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('AID — request for more information')}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M3 7l9 6 9-6"></path></svg>
        {CONTACT_EMAIL}
      </a>
    </p>
  </div>
</section>

<style>
  .fb {
    margin: 1.5rem 0 0;
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--casulo-radius, 12px);
    background: var(--sl-color-bg-nav);
    padding: 0;
    overflow: hidden;
  }
  .fb-tabs {
    display: flex;
    gap: 2px;
    padding: 6px 6px 0;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-inline-code);
  }
  .fb-tab {
    position: relative;
    padding: 10px 14px 11px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--sl-color-gray-2);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: var(--casulo-radius-sm, 8px) var(--casulo-radius-sm, 8px) 0 0;
    transition: color 0.15s, background 0.15s;
  }
  .fb-tab:hover { color: var(--sl-color-white); }
  .fb-tab.active { color: var(--sl-color-text-accent); font-weight: 650; }
  .fb-tab.active::after {
    content: "";
    position: absolute;
    left: 10px; right: 10px; bottom: -1px;
    height: 3px;
    background: var(--sl-color-accent);
    border-radius: 3px 3px 0 0;
  }
  .fb-note {
    margin: 0;
    padding: 12px 18px;
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--sl-color-gray-2);
    background: var(--casulo-accent-glow, rgba(212,168,83,.12));
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .fb-panel { padding: 18px; }
  .fb-desc { margin: 0 0 14px; font-size: 0.9rem; color: var(--sl-color-gray-2); }
  .fb-label {
    display: block;
    margin: 12px 0 5px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }
  .fb-label:first-of-type { margin-top: 0; }
  .fb-req { color: var(--sl-color-text-accent); }
  .fb-muted { color: var(--sl-color-gray-3); font-weight: 400; }
  .fb-input {
    width: 100%;
    padding: 8px 11px;
    border: 1px solid var(--casulo-border-strong, rgba(148,163,184,.16));
    border-radius: var(--casulo-radius-sm, 8px);
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    font: inherit;
    font-size: 0.9rem;
    line-height: 1.5;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .fb-input::placeholder { color: var(--sl-color-gray-3); }
  .fb-input:focus {
    outline: none;
    border-color: var(--sl-color-accent);
    box-shadow: 0 0 0 3px var(--casulo-accent-glow, rgba(212,168,83,.15));
  }
  .fb-input[readonly] { color: var(--sl-color-gray-2); background: var(--sl-color-bg-inline-code); }
  textarea.fb-input { resize: vertical; min-height: 64px; }
  .fb-invalid { border-color: #ef4444 !important; }
  .fb-submit {
    margin-top: 16px;
    padding: 9px 16px;
    border: 1px solid var(--casulo-border-accent, rgba(212,168,83,.3));
    border-radius: var(--casulo-radius-sm, 8px);
    background: var(--casulo-accent-glow, rgba(212,168,83,.15));
    color: var(--sl-color-text-accent);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .fb-submit:hover { background: var(--sl-color-accent); color: var(--sl-color-black); border-color: var(--sl-color-accent); }
  .fb-contact {
    padding: 18px;
    border-top: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-inline-code);
  }
  .fb-contact h3 { margin: 0 0 6px; font-size: 0.95rem; color: var(--sl-color-white); }
  .fb-contact p { margin: 0 0 8px; font-size: 0.88rem; color: var(--sl-color-gray-2); }
  .fb-mail {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--sl-color-text-accent);
    font-weight: 600;
    text-decoration: none;
  }
  .fb-mail:hover { text-decoration: underline; }
  .fb-mail svg { width: 16px; height: 16px; }
</style>

<script>
  (function () {
    const root = document.getElementById('aid-feedback');
    if (!root) return;
    const REPO = root.getAttribute('data-repo') || '';
    const NEW_ISSUE = 'https://github.com/' + REPO + '/issues/new';

    function openIssue(title: string, body: string, labels: string) {
      const p = new URLSearchParams();
      p.set('title', title);
      p.set('body', body);
      if (labels) p.set('labels', labels);
      window.open(NEW_ISSUE + '?' + p.toString(), '_blank', 'noopener,noreferrer');
    }

    const tabs = Array.from(root.querySelectorAll('[data-fbtab]'));
    const panels = Array.from(root.querySelectorAll('[data-fbpanel]')) as HTMLElement[];
    function select(name: string) {
      tabs.forEach(function (t) {
        const on = t.getAttribute('data-fbtab') === name;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      panels.forEach(function (pl) {
        pl.hidden = pl.getAttribute('data-fbpanel') !== name;
      });
    }
    tabs.forEach(function (t) {
      t.addEventListener('click', function () { select(t.getAttribute('data-fbtab') || ''); });
    });

    // Prefill from query params: ?type=page&page=<url>&title=<title>
    const params = new URLSearchParams(location.search);
    const pageUrl = params.get('page') || '';
    const pageTitle = params.get('title') || '';
    const pageField = root.querySelector('#fb-page-url') as HTMLInputElement | null;
    const pageTitleField = root.querySelector('#fb-page-title') as HTMLInputElement | null;
    if (pageField && pageUrl) pageField.value = pageUrl;
    if (pageTitleField && pageTitle) pageTitleField.value = pageTitle;
    if (params.get('type') === 'page') select('page');

    function val(sel: string): string {
      const el = root!.querySelector(sel) as HTMLInputElement | HTMLTextAreaElement | null;
      return el ? el.value.trim() : '';
    }
    function need(sel: string): boolean {
      const el = root!.querySelector(sel) as HTMLInputElement | HTMLTextAreaElement | null;
      if (el && !el.value.trim()) { el.classList.add('fb-invalid'); el.focus(); return false; }
      if (el) el.classList.remove('fb-invalid');
      return true;
    }
    const FOOTER = '\n\n---\n_Filed from the AID docs feedback form._';

    const pageSubmit = root.querySelector('#fb-page-submit');
    if (pageSubmit) pageSubmit.addEventListener('click', function () {
      if (!need('#fb-page-desc')) return;
      const pg = val('#fb-page-url');
      const ttl = val('#fb-page-title') || pg || 'a documentation page';
      openIssue('[Site] ' + ttl, '**Page:** ' + (pg || '(not specified)') + '\n\n**Issue:**\n' + val('#fb-page-desc') + FOOTER, 'site issue');
    });

    const bugSubmit = root.querySelector('#fb-bug-submit');
    if (bugSubmit) bugSubmit.addEventListener('click', function () {
      if (!need('#fb-bug-title') || !need('#fb-bug-what')) return;
      openIssue(
        '[Bug] ' + val('#fb-bug-title'),
        '**What happened:**\n' + val('#fb-bug-what') +
          '\n\n**Expected:**\n' + (val('#fb-bug-expected') || '(not specified)') +
          '\n\n**AID version / environment:**\n' + (val('#fb-bug-version') || '(not specified)') + FOOTER,
        'bug'
      );
    });

    const fbSubmit = root.querySelector('#fb-fb-submit');
    if (fbSubmit) fbSubmit.addEventListener('click', function () {
      if (!need('#fb-fb-subject') || !need('#fb-fb-msg')) return;
      openIssue('[Feedback] ' + val('#fb-fb-subject'), val('#fb-fb-msg') + FOOTER, 'feedback');
    });
  })();
</script>
