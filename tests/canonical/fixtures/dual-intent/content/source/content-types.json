{
  "contentTypes": [
    {
      "name": "Article",
      "requiredFields": ["title", "slug", "body", "publishedAt"],
      "optionalFields": ["summary", "tags", "author"],
      "slugPattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxBodyLength": 50000
    },
    {
      "name": "Tutorial",
      "requiredFields": ["title", "slug", "steps", "difficulty"],
      "optionalFields": ["prerequisites", "tags"],
      "difficulty": ["beginner", "intermediate", "advanced"],
      "slugPattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  ],
  "publishingStates": ["draft", "review", "published", "archived"]
}
