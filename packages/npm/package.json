{
  "name": "aid-installer",
  "version": "1.1.0",
  "description": "AID CLI installer - puts the persistent aid command on PATH via npm",
  "bin": {
    "aid": "bin/aid.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepack": "node scripts/vendor.js",
